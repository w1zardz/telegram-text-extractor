{
  "manifest_version": 3,
  "name": "Telegram Text Extractor — Copy from Protected Channels",
  "short_name": "TG Text Extractor",
  "version": "1.0.0",
  "description": "Copy text from Telegram Web channels and groups even when copying is disabled. Bulk copy, per-message copy, export to .txt.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Telegram Text Extractor — open panel",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.telegram.org/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "permissions": [
    "clipboardWrite",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://web.telegram.org/*"
  ],
  "homepage_url": "https://github.com/w1zardz/telegram-text-extractor"
}
